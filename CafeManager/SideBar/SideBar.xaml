<UserControl x:Class="CafeManager.SideBar.SideBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="200">
    
    <Border Background="{StaticResource SubmitBtnBrush}">
        <StackPanel>
            <TextBlock Text="Cafe Menu" 
                       Foreground="White" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Margin="15,20,15,20" 
                       HorizontalAlignment="Center"/>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="2" 
                       Grid.Column="0" 
                       Content="Jméno Příjmení"
                       Foreground="White"
                       FontSize="16"
                       Margin="10,10,0,10"/>
                <Button Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource ChangeBtnStyle}"/>
                
            </Grid>
            <Button Content="Objednávky" Margin="10,5" Padding="5"/>
            <Button Content="Sklad" Margin="10,5" Padding="5"/>
            <Button Content="⚙" Margin="60,40,60,5" Padding="5"/>
        </StackPanel>
    </Border>
</UserControl>